# Copy to .env (`cp .env.example .env`) before running. The .env file is gitignored.
# Every value has a safe default in docker-compose.yml, so the stack also runs
# with no .env at all — this file documents what is configurable.

# Host ports (left side of the compose port mappings)
APP_PORT=8001
PROMETHEUS_PORT=9090
LOKI_PORT=3100
GRAFANA_PORT=3001
ALERTMANAGER_PORT=9093
MAILPIT_UI_PORT=8025

# Grafana admin credentials. CHANGE THE PASSWORD for any non-local use.
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=admin
